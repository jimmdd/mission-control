{
  "name": "mission-control",
  "version": "1.0.0",
  "description": "Standalone mission control service for autonomous AI agent swarms",
  "type": "module",
  "main": "server.ts",
  "bin": {
    "mc": "./mc"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jimmdd/mission-control.git"
  },
  "author": "jimmdd",
  "license": "MIT",
  "keywords": [
    "mission-control",
    "task-management",
    "agent-tools",
    "agent-swarm",
