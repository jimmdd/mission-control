  },
  "dependencies": {
    "@opengsd/gsd-core": "^1.3.1",
    "@sinclair/typebox": "0.34.48",
    "better-sqlite3": "^12.6.2",
    "tsx": "^4.19.4"
  },
  "devDependencies": {
