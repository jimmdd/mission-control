{
  "agents": {
    "defaultProfile": "pi",
    "profiles": {
      "pi": {
        "launcher": "pi",
        "provider": "google",
        "model": "google/gemini-2.5-pro",
        "thinking": "high",
        "maxAgents": 5,
        "fallbackProfile": "codex",
        "env": {}
      },
      "claude": {
        "launcher": "claude",
        "model": "claude-opus-4-6",
        "fallbackModel": "",
        "maxAgents": 10,
        "fallbackProfile": "codex",
        "env": {}
      },
      "codex": {
        "launcher": "codex",
        "model": "gpt-5.4",
        "effort": "medium",
        "reviewEffort": "high",
        "maxAgents": 3,
        "env": {}
      },
      "ollama-local": {
        "launcher": "codex",
        "model": "qwen2.5-coder:14b",
        "effort": "medium",
        "maxAgents": 2,
        "env": {
          "OPENAI_BASE_URL": "http://127.0.0.1:11434/v1",
          "OPENAI_API_KEY": "ollama"
        }
      }
    }
  },
  "triage": {
    "triage_model": "gemini-2.5-flash",
    "triage_model_deep": "gemini-2.5-pro",
    "embedding_model": "gemini-embedding-001"
  },
  "knowledge": {
    "distill_model": "gemini-2.5-flash",
    "embedding_model": "gemini-embedding-001",
    "embedding_dimensions": 1536,
    "existing_schema": "context_fabrica",
    "existing_embedder": "fastembed",
    "existing_embedding_dimensions": 384
  },
  "planner": {
    "planning_model": "claude-sonnet-4-20250514",
    "planning_provider": "anthropic",
    "routing_model": "minimax-m2.7:cloud",
    "routing_provider": "ollama",
    "verification_model": "minimax-m2.7:cloud",
    "verification_provider": "ollama",
    "ollama_url": "http://localhost:11434",
    "max_step_retries": 2,
    "step_categories": {
      "deep": { "agent": "claude", "description": "Complex implementation" },
      "quick": { "agent": "pi", "description": "Simple, scoped change" },
      "test": { "agent": "codex", "description": "Writing or fixing tests" },
      "research": { "agent": "ollama-local", "description": "Investigation, no code changes" },
      "review": { "agent": "codex", "description": "Code review or validation" }
    }
  },
  "defaultProject": "your-project",
  "ciAutoFix": {
    "enabled": true,
    "maxCycles": 2
  },
  "reviewer": {
    "enabled": true,
    "reviewOnPush": true,
    "org": "YourOrg",
    "botUser": "your-bot-user",
    "repos": ["repo-1", "repo-2"]
  },
  "linear": {
    "enabled": true,
    "label": "your-label",
    "triageLabel": "your-triage-label",
    "mentionTag": "[mc-bot]",
    "botName": "Mission Control"
  }
}
